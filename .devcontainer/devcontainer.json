{
  "name": "Fullstack AI Sandbox",
  "build": {
    "dockerfile": "Dockerfile"
  },
  // ✅ No features block — docker-in-docker is handled in Dockerfile
  "runArgs": [
    "--privileged",
    "--init"
  ],
  "mounts": [
    // Mount host Docker socket into container
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "containerEnv": {
    "APP_ENV": "development",
    "DB_PASSWORD": "mock_password_for_dev"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "always",
          "source.organizeImports": "always"
        }
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "redhat.java",
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot",
        "vue.volar",
        "vue.vscode-typescript-vue-plugin",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "redhat.vscode-xml"
      ]
    }
  },
  "forwardPorts": [8080, 5173, 8000],
  "postCreateCommand": "sudo chown -R vscode:vscode /workspaces"
}